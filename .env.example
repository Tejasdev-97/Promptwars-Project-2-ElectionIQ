# ElectionIQ — Environment Variables
# Copy this file to env-config.js and fill in your actual API keys.
# NEVER commit env-config.js to version control.

# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Google APIs ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_TRANSLATE_API_KEY=your_translate_api_key_here
GOOGLE_CALENDAR_CLIENT_ID=your_calendar_oauth_client_id_here

# ── App Config ────────────────────────────────────────────────────────────────
APP_ENV=development
# Set to "production" when deploying
